{
  "name": "linearmouse-monorepo",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "pnpm --filter linearmouse-website dev",
    "dev:website": "pnpm --filter linearmouse-website dev",
    "dev:go": "pnpm --filter linearmouse-go dev",
    "dev:schema": "pnpm --filter linearmouse-schema dev",
    "build": "pnpm --filter linearmouse-website build && pnpm --filter linearmouse-go build && pnpm --filter linearmouse-schema build",
    "build:website": "pnpm --filter linearmouse-website build",
    "build:go": "pnpm --filter linearmouse-go build",
    "build:schema": "pnpm --filter linearmouse-schema build",
    "preview": "pnpm --filter linearmouse-website preview",
    "test": "pnpm --filter linearmouse-website test && pnpm --filter linearmouse-go test && pnpm --filter linearmouse-schema test",
    "test:website": "pnpm --filter linearmouse-website test",
    "test:go": "pnpm --filter linearmouse-go test",
    "test:schema": "pnpm --filter linearmouse-schema test",
    "deploy": "pnpm --filter linearmouse-website deploy",
    "deploy:website": "pnpm --filter linearmouse-website deploy",
    "deploy:go": "pnpm --filter linearmouse-go deploy",
    "deploy:schema": "pnpm --filter linearmouse-schema deploy",
    "cf-typegen": "pnpm --filter linearmouse-website cf-typegen && pnpm --filter linearmouse-go cf-typegen && pnpm --filter linearmouse-schema cf-typegen",
    "cf-typegen:website": "pnpm --filter linearmouse-website cf-typegen",
    "cf-typegen:go": "pnpm --filter linearmouse-go cf-typegen",
    "cf-typegen:schema": "pnpm --filter linearmouse-schema cf-typegen"
  }
}
