{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "linearmouse-go",
  "compatibility_date": "2026-03-21",
  "main": "./src/index.ts",
  "routes": [
    {
      "pattern": "go.linearmouse.app",
      "custom_domain": true
    }
  ],
  "preview_urls": true,
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  }
}
